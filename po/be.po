msgstr "Сапраўды незваротна выдаліць усе выдаленыя паведамленні з усіх папак?"

#: ../src/mail/mail.error.xml.h:42 ../src/modules/mail/e-mail-shell-view-actions.c:1602
msgid "_Empty Trash"
msgstr "_Спустошыць сметніцу"

